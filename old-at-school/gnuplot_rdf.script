
set terminal pngcairo size 5in,5in enhanced font 'Arial,10'
set output 'rdf_plot.png'

set key samplen 1 offset 0,-1

set format y "%.1f"
set format x "%.0f"
set xlabel "r (pm)"
set ylabel "g(r)"
set xtics 100

p 'rdf.dft.6000K_2.5gcc' w l lw 2 lc  4 t 'DFT', \
  'rdf.mio.6000K_2.5gcc' w l lw 2 lc 11 t 'DFTB'#, \
#  'DFTref_E_xeqy.txt'              w l lt -1 lc -1 t 'x = y'
 
